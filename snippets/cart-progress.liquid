{% assign item_count = cart.item_count %}
{% assign cart_total = cart.total_price %}
{% assign base_product = all_products['bergamot-pepper-ambroxan'] %}
{% assign milestone_amount = base_product.price | times: 6.3 %}
{% assign milestone_3_plus_1 = base_product.price | times: 3.1 %}
{% assign milestone_50_euro = 50.00 %}
{% assign more_amount = milestone_amount | minus: cart_total %}
{% assign more_amount_3_plus_1 = milestone_3_plus_1 | minus: cart_total %}
{% assign more_amount_50_euro = milestone_50_euro | minus: cart_total %}

{% if item_count > 0 %}
  <div class="pb-4">
    {% if cart_total > milestone_amount %}
      <div class="text-base font-semibold text-center mb-6">Congratulations! You have unlocked free shipping!</div>
    {% elsif cart_total > milestone_3_plus_1 %}
      <div class="text-base font-semibold text-center mb-6">Add {{ more_amount_3_plus_1 | money }} more to unlock free shipping!</div>
    {% elsif cart_total > milestone_50_euro %}
      <div class="text-base font-semibold text-center mb-6">Add {{ more_amount_50_euro | money }} more to unlock free shipping!</div>
    {% else %}
      <div class="text-base font-semibold text-center mb-6">Add {{ milestone_50_euro | money }} more to unlock free shipping!</div>
    {% endif %}

    <div class="relative h-3 bg-gray-200 rounded-full mb-4">
      <!-- Progress bar -->
      <div
        class="absolute top-0 left-0 h-full bg-[#ac8956] !block rounded-full"
        style="width: {{ cart_total | times: 50 | divided_by: milestone_amount }}%;"
        id="progress-bar"></div>

      <!-- Checkpoint indicators -->
      <div class="absolute top-[-15px] left-[10%] [transform:translateX(-50%)] bg-white border-2 border-solid rounded-full text-xs border-gray-200" id="checkpoint-3-plus-1">
        <span class="text-xs leading-none font-bold text-center">3+1</span>
      </div>

      <div class="absolute top-[-15px] left-[50%] [transform:translateX(-50%)] bg-white border-2 border-solid rounded-full text-xs {% if milestone_amount > cart_total %}border-gray-200{% else %}border-[#ac8956]{% endif %}" id="shipping-pill">
        <span class="text-xs leading-none font-bold text-center">Free Ship</span>
      </div>

      <div class="absolute top-[-15px] left-[90%] [transform:translateX(-50%)] bg-white border-2 border-solid rounded-full text-xs {% if milestone_50_euro > cart_total %}border-gray-200{% else %}border-[#ac8956]{% endif %}" id="checkpoint-50-euro">
        <span class="text-xs leading-none font-bold text-center">€50</span>
      </div>
    </div>
  </div>
{% endif %}