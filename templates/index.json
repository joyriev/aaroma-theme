        "review_j8wKcd": {
          "type": "review",
          "settings": {
            "content": "<p>\"Na een kleine vertraging heb ik eindelijk mijn TryScent parfums ontvangen en ze zijn precies goed! Ik kan haast niet geloven hoe nauwkeurig ze zijn ten opzichte van de originelen. Ter referentie: ik kreeg \"Ylang Ylang Rose Jasmine\" en \"Aldehydes Rose Sandalwood\" — het zijn echt prachtige geuren\"</p>",
            "author": "Gabriella K",
