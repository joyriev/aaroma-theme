        "review_ByDgLX": {
          "type": "review",
          "settings": {
            "content": "<p>\"Dit is het beste parfum dat ik in heel lange tijd heb geroken. De noten maken me krankzinnig van geluk. Ik zal dit voor altijd in mijn rotatie houden.\"</p>",
