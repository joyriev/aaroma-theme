        "review_7Cz3ck": {
          "type": "review",
          "settings": {
            "content": "<p>\"Ruikt precies zoals Luna Rossa Carbon, maar veel goedkoper. Ik kan niet geloven hoe dicht het erbij ligt.\"</p>",
            "author": "Robinson D.",
