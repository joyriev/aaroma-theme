    "massive_review_bRbA9R": {
      "type": "massive-review",
      "blocks": {
        "review_8gHPQW": {
          "type": "review",
          "settings": {
            "content": "<p>\"Dit is mijn eerste aankoop en ik ben verslaafd. Ik zal nooit meer ergens anders parfum kopen. Ik kon nooit een dupe-geur vinden die echt authentiek en consistent rook.\"</p>",
            "author": "Killian P.",
            "date": "1 dag geleden",
            "rating": 5,
